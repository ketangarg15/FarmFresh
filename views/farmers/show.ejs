<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= farmer.name %> - Farmer Profile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/farmers.css">
</head>
<body>
  <%- include('../partials/header') %>

  <div class="container py-5">
    <div class="card shadow-lg border-0 mx-auto" style="max-width: 800px;">
      <div class="row g-0">
        <div class="col-md-5">
          <img src="/assets/images/farmer.jpg" alt="<%= farmer.name %>" class="img-fluid rounded-start h-100 object-fit-cover">
        </div>
        <div class="col-md-7">
          <div class="card-body">
            <h3 class="card-title fw-bold"><%= farmer.name %></h3>
            <p class="text-muted mb-1"><strong>📍 Location:</strong> <%= farmer.location %></p>
            <p class="text-muted mb-1"><strong>🌾 Experience:</strong> <%= farmer.experience %></p>
            <p class="text-muted mb-1"><strong>📧 Contact:</strong> <%= farmer.contact %></p>
            <p class="text-muted mb-3"><strong>📞 Phone:</strong> <%= farmer.phone %></p>
            <hr>
            <h5 class="fw-semibold text-success mb-2">Struggle Story</h5>
            <p class="text-secondary" style="text-align: justify;"><%= farmer.story %></p>
            <a href="/farmers" class="btn btn-outline-success mt-3">← Back to Farmers</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
