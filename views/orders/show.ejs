<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details - <%= (order._id || order.id || '').toString().slice(-8).toUpperCase() %> - FarmFresh</title>
    <link rel="stylesheet" href="/css/order-show.css">
</head>
<body>
    <%- include('../partials/flash') %>
    
    <div class="order-show-container">
        <header class="order-show-header">
            <nav class="order-show-nav">
                <div class="order-show-nav-brand">
                    <a href="/"><h1>FarmFresh</h1></a>
                </div>
                <ul class="order-show-nav-links">
                    <li><a href="/" class="order-show-nav-link">Home</a></li>
                    <li><a href="/products" class="order-show-nav-link">Products</a></li>
                    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <li><a href="/dashboard/<%= currentUser.role %>" class="order-show-nav-link">Dashboard</a></li>
                        <li><a href="/orders" class="order-show-nav-link">Orders</a></li>
                        <li><a href="/logout" class="order-show-nav-link">Logout</a></li>
                    <% } else { %>
                        <li><a href="/login" class="order-show-nav-link">Login</a></li>
                        <li><a href="/signup" class="order-show-nav-link">Signup</a></li>
                    <% } %>
                </ul>
            </nav>
        </header>

        <div class="order-show-breadcrumb">
            <div class="order-show-breadcrumb-content">
                <a href="/" class="order-show-breadcrumb-link">Home</a>
                <span class="order-show-breadcrumb-separator">›</span>
                <a href="/dashboard/<%= currentUser.role %>" class="order-show-breadcrumb-link">Dashboard</a>
                <span class="order-show-breadcrumb-separator">›</span>
                <a href="/orders" class="order-show-breadcrumb-link">My Orders</a>
                <span class="order-show-breadcrumb-separator">›</span>
                <span class="order-show-breadcrumb-current">
                    Order #<%= (order._id || order.id || '').toString().slice(-8).toUpperCase() %>
                </span>
            </div>
        </div>

        <main class="order-show-main">
            <div class="order-show-content">
                <div class="order-receipt">
                    <div class="receipt-header">
                        <div class="receipt-title-section">
                            <h1 class="receipt-title">Order Receipt</h1>
                            <div class="receipt-order-id">
                                Order #<%= (order._id || order.id || '').toString().slice(-8).toUpperCase() %>
                            </div>
                        </div>
                        
                        <div class="receipt-status-section">
                            <span class="receipt-status-badge receipt-status-<%= (order.status || 'pending').toLowerCase() %>">
                                <%= (order.status || 'Pending').charAt(0).toUpperCase() + (order.status || 'pending').slice(1) %>
                            </span>
                            <div class="receipt-date">
                                <%= new Date(order.createdAt || new Date()).toLocaleString('en-US', { 
                                    weekday: 'long',
                                    year: 'numeric', 
                                    month: 'long', 
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit'
                                }) %>
                            </div>
                        </div>
                    </div>

                    <div class="receipt-section">
                        <h3 class="receipt-section-title">Customer Information</h3>
                        <div class="receipt-customer-info">
                            <div class="customer-detail">
                                <span class="customer-label">Name:</span>
                                <span class="customer-value">
                                    <%= (order.consumer && (order.consumer.name || order.consumer.firstName + ' ' + (order.consumer.lastName || ''))) || 
                                        (currentUser && (currentUser.name || currentUser.firstName + ' ' + (currentUser.lastName || ''))) || 'Customer Name' %>
                                </span>
                            </div>
                            <div class="customer-detail">
                                <span class="customer-label">Email:</span>
                                <span class="customer-value">
                                    <%= (order.consumer && order.consumer.email) || (currentUser && currentUser.email) || 'customer@email.com' %>
                                </span>
                            </div>
                            <% if (order.consumer && order.consumer.phone) { %>
                                <div class="customer-detail">
                                    <span class="customer-label">Phone:</span>
                                    <span class="customer-value"><%= order.consumer.phone %></span>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <% if (order.deliveryInfo || order.shippingAddress) { %>
                        <div class="receipt-section">
                            <h3 class="receipt-section-title">Delivery Information</h3>
                            <div class="receipt-delivery-info">
                                <% if (order.deliveryInfo && order.deliveryInfo.address) { %>
                                    <div class="delivery-address">
                                        <div class="delivery-label">Delivery Address:</div>
                                        <div class="delivery-value">
                                            <%= order.deliveryInfo.address.street || '' %><br>
                                            <%= order.deliveryInfo.address.city || '' %>, 
                                            <%= order.deliveryInfo.address.state || '' %> 
                                            <%= order.deliveryInfo.address.zipCode || '' %>
                                        </div>
                                    </div>
                                <% } else if (order.shippingAddress) { %>
                                    <div class="delivery-address">
                                        <div class="delivery-label">Delivery Address:</div>
                                        <div class="delivery-value">
                                            <%= order.shippingAddress.street || order.shippingAddress %><br>
                                            <% if (typeof order.shippingAddress === 'object') { %>
                                                <%= order.shippingAddress.city || '' %>, 
                                                <%= order.shippingAddress.state || '' %> 
                                                <%= order.shippingAddress.zipCode || '' %>
                                            <% } %>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <% if (order.deliveryInfo && order.deliveryInfo.instructions) { %>
                                    <div class="delivery-instructions">
                                        <div class="delivery-label">Special Instructions:</div>
                                        <div class="delivery-value"><%= order.deliveryInfo.instructions %></div>
                                    </div>
                                <% } %>
                                
                                <% if (order.deliveryInfo && order.deliveryInfo.preferredTime) { %>
                                    <div class="delivery-time">
                                        <div class="delivery-label">Preferred Delivery Time:</div>
                                        <div class="delivery-value"><%= order.deliveryInfo.preferredTime %></div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% } %>

                    <div class="receipt-section">
                        <h3 class="receipt-section-title">Order Items</h3>
                        <div class="receipt-items">
                            <% if (order.products && order.products.length > 0) { %>
                                <% let subtotal = 0; %>
                                <% order.products.forEach(function(item) { %>
                                    <% 
                                        const itemPrice = (item.product && item.product.price) || item.price || 0;
                                        const itemQuantity = item.quantity || 1;
                                        const itemTotal = itemPrice * itemQuantity;
                                        subtotal += itemTotal;
                                    %>
                                    <div class="receipt-item">
                                        <div class="receipt-item-image">
                                            <img 
                                                src="<%= (item.product && (item.product.image || item.product.imageUrl)) || '/images/placeholder-product.jpg' %>" 
                                                alt="<%= (item.product && item.product.name) || 'Product' %>"
                                                class="receipt-product-img"
                                            >
                                        </div>
                                        
                                        <div class="receipt-item-details">
                                            <h4 class="receipt-item-name">
                                                <% if (item.product && item.product._id) { %>
                                                    <a href="/products/<%= item.product._id || item.product.id %>" class="receipt-product-link">
                                                        <%= item.product.name || 'Product Name' %>
                                                    </a>
                                                <% } else { %>
                                                    <%= (item.product && item.product.name) || item.name || 'Product Name' %>
                                                <% } %>
                                            </h4>
                                            
                                            <div class="receipt-item-meta">
                                                <% if (item.product && item.product.category) { %>
                                                    <span class="receipt-item-category">
                                                        <%= item.product.category.charAt(0).toUpperCase() + item.product.category.slice(1) %>
                                                    </span>
                                                <% } %>
                                                
                                                <% if (item.product && item.product.farmer) { %>
                                                    <span class="receipt-item-farmer">
                                                        by <%= (item.product.farmer.name || item.product.farmer.firstName + ' ' + (item.product.farmer.lastName || '')) || 'Farmer' %>
                                                    </span>
                                                <% } %>
                                            </div>
                                            
                                            <% if (item.product && item.product.description) { %>
                                                <div class="receipt-item-description">
                                                    <%= item.product.description.substring(0, 100) %><%= item.product.description.length > 100 ? '...' : '' %>
                                                </div>
                                            <% } %>
                                        </div>
                                        
                                        <div class="receipt-item-quantity">
                                            <div class="quantity-section">
                                                <span class="quantity-label">Qty:</span>
                                                <span class="quantity-value"><%= itemQuantity %></span>
                                            </div>
                                            <div class="price-section">
                                                <span class="unit-price">$<%= itemPrice.toFixed(2) %> each</span>
                                            </div>
                                        </div>
                                        
                                        <div class="receipt-item-total">
                                            $<%= itemTotal.toFixed(2) %>
                                        </div>
                                    </div>
                                <% }); %>
                                
                                <div class="receipt-summary">
                                    <div class="summary-row">
                                        <span class="summary-label">Subtotal:</span>
                                        <span class="summary-value">$<%= subtotal.toFixed(2) %></span>
                                    </div>
                                    
                                    <% 
                                        const deliveryFee = (order.deliveryFee !== undefined) ? order.deliveryFee : (subtotal * 0.1);
                                        const tax = (order.tax !== undefined) ? order.tax : (subtotal * 0.08);
                                        const discount = order.discount || 0;
                                    %>
                                    
                                    <div class="summary-row">
                                        <span class="summary-label">Delivery Fee:</span>
                                        <span class="summary-value">$<%= deliveryFee.toFixed(2) %></span>
                                    </div>
                                    
                                    <div class="summary-row">
                                        <span class="summary-label">Tax:</span>
                                        <span class="summary-value">$<%= tax.toFixed(2) %></span>
                                    </div>
                                    
                                    <% if (discount > 0) { %>
                                        <div class="summary-row summary-discount">
                                            <span class="summary-label">Discount:</span>
                                            <span class="summary-value">-$<%= discount.toFixed(2) %></span>
                                        </div>
                                    <% } %>
                                    
                                    <div class="summary-row summary-total">
                                        <span class="summary-label">Total:</span>
                                        <span class="summary-value">$<%= (order.totalAmount || 0).toFixed(2) %></span>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="receipt-items-empty">
                                    <p>No items found in this order.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="receipt-section">
                        <h3 class="receipt-section-title">Payment Information</h3>
                        <div class="receipt-payment-info">
                            <div class="payment-detail">
                                <span class="payment-label">Payment Method:</span>
                                <span class="payment-value">
                                    <%= (order.paymentMethod && order.paymentMethod.type) || 'Credit Card' %>
                                    <% if (order.paymentMethod && order.paymentMethod.last4) { %>
                                        ending in <%= order.paymentMethod.last4 %>
                                    <% } %>
                                </span>
                            </div>
                            <div class="payment-detail">
                                <span class="payment-label">Payment Status:</span>
                                <span class="payment-value payment-status-<%= (order.paymentStatus || 'paid').toLowerCase() %>">
                                    <%= (order.paymentStatus || 'Paid').charAt(0).toUpperCase() + (order.paymentStatus || 'paid').slice(1) %>
                                </span>
                            </div>
                            <% if (order.transactionId) { %>
                                <div class="payment-detail">
                                    <span class="payment-label">Transaction ID:</span>
                                    <span class="payment-value"><%= order.transactionId %></span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="order-timeline-container">
                    <h3 class="timeline-title">Order Timeline</h3>
                    <div class="order-timeline">
                        <% 
                            const timelineSteps = [
                                { status: 'pending', label: 'Order Placed', icon: '📝' },
                                { status: 'confirmed', label: 'Order Confirmed', icon: '✅' },
                                { status: 'dispatched', label: 'Order Dispatched', icon: '🚚' },
                                { status: 'delivered', label: 'Order Delivered', icon: '📦' }
                            ];
                            
                            const currentStatus = (order.status || 'pending').toLowerCase();
                            const currentStatusIndex = timelineSteps.findIndex(step => step.status === currentStatus);
                        %>
                        
                        <% timelineSteps.forEach(function(step, index) { %>
                            <% 
                                let stepClass = 'timeline-step';
                                if (index <= currentStatusIndex) {
                                    stepClass += ' timeline-step-completed';
                                } else if (index === currentStatusIndex + 1) {
                                    stepClass += ' timeline-step-current';
                                }
                                
                                // Check if we have specific timestamp for this step
                                let stepDate = null;
                                if (order.statusHistory && order.statusHistory.length > 0) {
                                    const historyItem = order.statusHistory.find(h => h.status === step.status);
                                    if (historyItem) {
                                        stepDate = historyItem.timestamp || historyItem.date;
                                    }
                                }
                                
                                // Use order creation date for 'pending' status
                                if (step.status === 'pending' && !stepDate) {
                                    stepDate = order.createdAt;
                                }
                            %>
                            
                            <div class="<%= stepClass %>">
                                <div class="timeline-step-icon">
                                    <%= step.icon %>
                                </div>
                                <div class="timeline-step-content">
                                    <div class="timeline-step-label"><%= step.label %></div>
                                    <% if (stepDate) { %>
                                        <div class="timeline-step-date">
                                            <%= new Date(stepDate).toLocaleString('en-US', { 
                                                month: 'short', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                        
                        <% if (currentStatus === 'cancelled') { %>
                            <div class="timeline-step timeline-step-cancelled">
                                <div class="timeline-step-icon">❌</div>
                                <div class="timeline-step-content">
                                    <div class="timeline-step-label">Order Cancelled</div>
                                    <% if (order.cancelledAt) { %>
                                        <div class="timeline-step-date">
                                            <%= new Date(order.cancelledAt).toLocaleString('en-US', { 
                                                month: 'short', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (order.products && order.products.length > 0) { %>
                    <% 
                        // Get unique farmers from order products
                        const farmers = [];
                        order.products.forEach(item => {
                            if (item.product && item.product.farmer) {
                                const farmer = item.product.farmer;
                                if (!farmers.find(f => (f._id || f.id) === (farmer._id || farmer.id))) {
                                    farmers.push(farmer);
                                }
                            }
                        });
                    %>
                    
                    <% if (farmers.length > 0) { %>
                        <div class="farmer-contact-container">
                            <h3 class="farmer-contact-title">Contact Your Farmers</h3>
                            <div class="farmer-contact-list">
                                <% farmers.forEach(function(farmer) { %>
                                    <div class="farmer-contact-card">
                                        <div class="farmer-info">
                                            <% if (farmer.profileImage || farmer.avatar) { %>
                                                <img 
                                                    src="<%= farmer.profileImage || farmer.avatar %>" 
                                                    alt="<%= farmer.name || farmer.firstName + ' ' + (farmer.lastName || '') %>"
                                                    class="farmer-avatar"
                                                >
                                            <% } else { %>
                                                <div class="farmer-avatar-placeholder">
                                                    <%= ((farmer.name || farmer.firstName || 'F').charAt(0)).toUpperCase() %>
                                                </div>
                                            <% } %>
                                            
                                            <div class="farmer-details">
                                                <h4 class="farmer-name">
                                                    <%= farmer.name || farmer.firstName + ' ' + (farmer.lastName || '') %>
                                                </h4>
                                                <% if (farmer.farmName) { %>
                                                    <div class="farmer-farm-name"><%= farmer.farmName %></div>
                                                <% } %>
                                                <% if (farmer.location) { %>
                                                    <div class="farmer-location">📍 <%= farmer.location %></div>
                                                <% } %>
                                            </div>
                                        </div>
                                        
                                        <div class="farmer-contact-actions">
                                            <a href="/farmers/<%= farmer._id || farmer.id %>" class="farmer-action-btn farmer-action-profile">
                                                View Profile
                                            </a>
                                            
                                            <a href="/messages/new?farmer=<%= farmer._id || farmer.id %>&order=<%= order._id || order.id %>" class="farmer-action-btn farmer-action-message">
                                                Send Message
                                            </a>
                                            
                                            <% if (farmer.phone) { %>
                                                <a href="tel:<%= farmer.phone %>" class="farmer-action-btn farmer-action-phone">
                                                    📞 Call
                                                </a>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                <% } %>

                <div class="order-actions-container">
                    <div class="order-actions">
                        <a href="/orders" class="order-action-btn order-action-back">
                            ← Back to Orders
                        </a>
                        
                        <button type="button" class="order-action-btn order-action-print" onclick="window.print()">
                            🖨️ Print Receipt
                        </button>
                        
                        <% if ((order.status || 'pending').toLowerCase() === 'pending') { %>
                            <button 
                                type="button" 
                                class="order-action-btn order-action-cancel" 
                                id="cancelOrderBtn"
                                data-order-id="<%= order._id || order.id %>"
                            >
                                ❌ Cancel Order
                            </button>
                        <% } %>
                        
                        <button 
                            type="button" 
                            class="order-action-btn order-action-reorder" 
                            id="reorderBtn"
                            data-order-id="<%= order._id || order.id %>"
                        >
                            🔄 Reorder Items
                        </button>
                        
                        <a href="/orders/<%= order._id || order.id %>/receipt.pdf" class="order-action-btn order-action-download" target="_blank">
                            📄 Download PDF
                        </a>
                        
                        <% if ((order.status || 'pending').toLowerCase() === 'delivered') { %>
                            <a href="/orders/<%= order._id || order.id %>/review" class="order-action-btn order-action-review">
                                ⭐ Write Review
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>

        <footer class="order-show-footer">
            <div class="order-show-footer-content">
                <p>&copy; 2024 FarmFresh. All rights reserved.</p>
                <div class="order-show-footer-links">
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                    <a href="/terms">Terms</a>
                    <a href="/privacy">Privacy</a>
                    <a href="/help">Help</a>
                </div>
            </div>
        </footer>
    </div>

    <script src="/js/order-show.js"></script>
</body>
</html>