<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders - FarmFresh</title>
    <link rel="stylesheet" href="/css/orders.css">
</head>
<body>
    <div class="orders-container">
        <header class="orders-header">
            <%- include('../partials/header') %>
        </header>

        <div class="orders-breadcrumb">
            <div class="orders-breadcrumb-content">
                <a href="/" class="orders-breadcrumb-link">Home</a>
                <span class="orders-breadcrumb-separator">›</span>
                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <a href="/dashboard/<%= currentUser.role %>" class="orders-breadcrumb-link">Dashboard</a>
                    <span class="orders-breadcrumb-separator">›</span>
                <% } %>
                <span class="orders-breadcrumb-current">My Orders</span>
            </div>
        </div>

        <main class="orders-main">
            <div class="orders-content">
                <div class="orders-page-header">
                    <div class="orders-title-section">
                        <h1 class="orders-title">My Orders</h1>
                        <p class="orders-subtitle">Track and manage all your past and current orders.</p>
                    </div>
                    
                    <div class="orders-stats">
                        </div>
                </div>

                <div class="orders-filters">
                    </div>

                <div class="orders-list-container">
                    <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                        <div class="orders-list" id="ordersList">
                            <% orders.forEach(function(order, index) { %>
                                <div class="orders-item" data-status="<%= order.status || 'pending' %>" data-amount="<%= order.totalAmount || 0 %>" data-date="<%= order.createdAt || new Date() %>">
                                    <div class="orders-item-header" onclick="toggleOrderDetails('<%= index %>')">
                                        <div class="orders-item-main">
                                            <div class="orders-item-id">
                                                <a href="/orders/<%= order._id || order.id %>" class="orders-item-link">
                                                    Order #<%= (order._id || order.id || '').toString().slice(-8).toUpperCase() %>
                                                </a>
                                            </div>
                                            
                                            <div class="orders-item-status">
                                                <span class="orders-status-badge orders-status-<%= (order.status || 'pending').toLowerCase() %>">
                                                    <%= (order.status || 'Pending').charAt(0).toUpperCase() + (order.status || 'pending').slice(1) %>
                                                </span>
                                            </div>
                                            
                                            <div class="orders-item-date">
                                                </div>
                                            
                                            <div class="orders-item-total">
                                                <span class="orders-total-amount">
                                                    ₹<%= (order.totalAmount || 0).toFixed(2) %>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="orders-item-toggle">
                                            </div>
                                    </div>

                                    <div class="orders-item-details" id="orderDetails<%= index %>" style="display: none;">
                                        <div class="orders-products-section">
                                            <h4 class="orders-products-title">Items Ordered:</h4>
                                            <div class="orders-products-list">
                                                <% if (order.products && order.products.length > 0) { %>
                                                    <% order.products.forEach(function(item) { %>
                                                        <div class="orders-product-item">
                                                            <div class="orders-product-info">
                                                                <div class="orders-product-details">
                                                                    <span class="orders-product-quantity">Qty: <%= item.quantity || 1 %></span>
                                                                    <span class="orders-product-price">
                                                                        ₹<%= ((item.product && item.product.price) || item.price || 0).toFixed(2) %> each
                                                                    </span>
                                                                </div>
                                                                </div>
                                                            <div class="orders-product-total">
                                                                ₹<%= (((item.product && item.product.price) || item.price || 0) * (item.quantity || 1)).toFixed(2) %>
                                                            </div>
                                                        </div>
                                                    <% }); %>
                                                <% } %>
                                            </div>
                                        </div>
                                        
                                        <div class="orders-summary-section">
                                            <div class="orders-summary-row">
                                                <span class="orders-summary-label">Subtotal:</span>
                                                <span class="orders-summary-value">
                                                    ₹<%= ((order.totalAmount || 0) * 0.9).toFixed(2) %>
                                                </span>
                                            </div>
                                            <div class="orders-summary-row">
                                                <span class="orders-summary-label">Delivery Fee:</span>
                                                <span class="orders-summary-value">
                                                    ₹<%= ((order.totalAmount || 0) * 0.1).toFixed(2) %>
                                                </span>
                                            </div>
                                            <div class="orders-summary-row orders-summary-total">
                                                <span class="orders-summary-label">Total:</span>
                                                <span class="orders-summary-value">
                                                    ₹<%= (order.totalAmount || 0).toFixed(2) %>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="orders-actions-section">
                                            </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <% } %>
                </div>
            </div>
        </main>

        <footer class="orders-footer">
            <%- include('../partials/footer') %>
        </footer>
    </div>

    <script src="/js/base.js" defer></script>
    <script src="/js/orders.js" defer></script>
</body>
</html>