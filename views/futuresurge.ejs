<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Future Price Surge - FarmFresh</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .surge-card img {
      height: 220px;
      object-fit: cover;
      border-radius: 10px;
    }
    .price-increase {
      font-weight: bold;
      color: #e63946;
    }
    .badge-scarcity {
      background-color: #ffb703;
      color: #000;
      font-weight: 600;
    }
    .card {
      transition: transform 0.3s ease;
    }
    .card:hover {
      transform: scale(1.03);
    }
  </style>
</head>
<body>
  <%- include('./partials/header') %>

  <div class="container py-5">
    <h1 class="text-center mb-4 text-success fw-bold">🌾 Future Price Surge</h1>
    <p class="text-center text-muted mb-5">
      Stay ahead! These essential items are expected to see price increases due to upcoming scarcity. 
      Stock up before they become expensive.
    </p>

    <div class="row g-4">
      <% const products = [
        {
          name: 'Onion',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757499155/FarmFresh/hddxdji46picfwjlkerz.jpg',
          currentPrice: 45,
          futurePrice: 90,
          id: '68c14f12588a24e55c8bfb30'
        },
        {
          name: 'Tomato',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757410179/FarmFresh/t46bhcgmlg5yspzzid8i.jpg',
          currentPrice: 40,
          futurePrice: 80,
          id: '68bff383ef028d7f5e631673'
        },
        {
          name: 'Pure Honey',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757523695/FarmFresh/sfise0d6sunjdhm5lum8.jpg',
          currentPrice: 700,
          futurePrice: 1200,
          id: '68c1aef0caf6b529cd97ad42'
        },
        {
          name: 'Berries',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757524220/FarmFresh/n5sj7u9uopbgc1mwnhn5.jpg',
          currentPrice: 480,
          futurePrice: 800,
          id: '68c1b0fdcaf6b529cd97b9a7'
        },
        {
          name: 'Paneer',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757523629/FarmFresh/xq1ggpkdv7cylgki9jnd.jpg',
          currentPrice: 600,
          futurePrice: 1000,
          id: '68c1aeafcaf6b529cd97a7fd'
        },
        {
          name: 'Guava',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757524268/FarmFresh/wkqogdi5jubgfveaadep.jpg',
          currentPrice: 70,
          futurePrice: 130,
          id: '68c1b12dcaf6b529cd97bd45'
        },
        {
          name: 'Fish',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757524881/FarmFresh/zzezgszvvdhaorljsexs.jpg',
          currentPrice: 300,
          futurePrice: 550,
          id: '68c1b392caf6b529cd97ca58'
        },
        {
          name: 'Banana',
          image: 'https://res.cloudinary.com/drezimmb1/image/upload/v1757410116/FarmFresh/fpaaftb1pw7xfc31njju.jpg',
          currentPrice: 60,
          futurePrice: 100,
          id: '68bff344ef028d7f5e6311a7'
        }
      ]; %>

      <% products.forEach(p => { 
          const increasePercent = (((p.futurePrice - p.currentPrice) / p.currentPrice) * 100).toFixed(0);
      %>
        <div class="col-md-4 col-sm-6">
          <div class="card surge-card shadow-sm border-0">
            <img src="<%= p.image %>" alt="<%= p.name %>" class="card-img-top">
            <div class="card-body text-center">
              <h5 class="card-title fw-bold"><%= p.name %></h5>
              <p class="text-muted mb-1">Current Price: ₹<%= p.currentPrice %></p>
              <p class="text-danger mb-1">Expected Price: ₹<%= p.futurePrice %></p>
              <span class="badge badge-scarcity mb-2">Scarcity Alert</span>
              <p class="price-increase">📈 +<%= increasePercent %>% Expected Increase</p>
              <a href="/products/<%= p.id %>" class="btn btn-outline-success mt-2">View Product</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <%- include('./partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
