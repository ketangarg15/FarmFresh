<%# This single, dynamic block is cleaner and easier to maintain %>
<% if (typeof messages !== 'undefined' && Object.keys(messages).length > 0) { %>
    <div class="flash-container" id="flash-container">
        <% 
            // Helper object to map message categories to icons
            const icons = {
                success: '✅',
                error: '❌',
                warning: '⚠️',
                info: 'ℹ️'
            };
        %>

        <% Object.keys(messages).forEach(category => { %>
            <% if (messages[category] && messages[category].length) { %>
                <% messages[category].forEach(msg => { %>
                    <div class="flash-message flash-<%= category %>" role="alert" aria-live="<%= category === 'error' ? 'assertive' : 'polite' %>">
                        <span class="flash-icon"><%= icons[category] || '🔔' %></span>
                        <span class="flash-text"><%= msg %></span>
                    </div>
                <% }) %>
            <% } %>
        <% }) %>
    </div>
    <script>
        (function(){
            if (window.__flashInit) return; 
            window.__flashInit = true;

            function dismiss(el){
                if(!el) return;
                el.classList.add('fade-out');
                var removed = false;
                var removeNow = function(){ if(removed) return; removed = true; el.remove(); };
                el.addEventListener('transitionend', removeNow, { once: true });
                setTimeout(removeNow, 600);
            }

            function wireMessage(message){
                if(!message || message.__wired) return; message.__wired = true;
                // Ensure only one visible flash at a time
                try {
                    var all = document.querySelectorAll('.flash-message');
                    all.forEach(function(m){ if(m !== message) dismiss(m); });
                } catch(_){}
                setTimeout(function(){ dismiss(message); }, 3000);
            }

            // Wire existing messages
            var existing = document.querySelectorAll('.flash-message');
            existing.forEach(wireMessage);

            // Observe for new flash messages inserted later
            var container = document.getElementById('flash-container');
            if (container && window.MutationObserver){
                var obs = new MutationObserver(function(mutations){
                    mutations.forEach(function(m){
                        m.addedNodes && m.addedNodes.forEach(function(node){
                            if(node.nodeType === 1){
                                if(node.classList.contains('flash-message')) wireMessage(node);
                                node.querySelectorAll && node.querySelectorAll('.flash-message').forEach(wireMessage);
                            }
                        });
                    });
                });
                obs.observe(container, { childList: true, subtree: true });
            }
        })();
    </script>
<% } %>