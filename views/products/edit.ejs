<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= product.name %> - FarmFresh</title>
    <link rel="stylesheet" href="/css/product-form.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="product-form-container">
        <header class="product-form-header">
            <nav class="product-form-nav">
                <div class="product-form-nav-brand">
                    <a href="/"><h1>FarmFresh</h1></a>
                </div>
                </nav>
        </header>

        <div class="product-form-breadcrumb">
            <div class="product-form-breadcrumb-content">
                <a href="/" class="product-form-breadcrumb-link">Home</a>
                <span class="product-form-breadcrumb-separator">›</span>
                <a href="/products" class="product-form-breadcrumb-link">Products</a>
                <span class="product-form-breadcrumb-separator">›</span>
                <a href="/products/<%= product._id %>" class="product-form-breadcrumb-link"><%= product.name %></a>
                <span class="product-form-breadcrumb-separator">›</span>
                <span class="product-form-breadcrumb-current">Edit</span>
            </div>
        </div>

        <main class="product-form-main">
            <div class="product-form-content">
                <div class="product-form-title-section">
                    <h2 class="product-form-title">Edit Product</h2>
                    <p class="product-form-subtitle">Update your product information below.</p>
                </div>

                <div class="product-form-wrapper">
                    <form method="POST" action="/products/<%= product._id %>?_method=PUT" class="product-form" id="productForm" enctype="multipart/form-data">
                        <div class="product-form-grid">
                            <div class="product-form-fields">
                                <div class="product-form-group">
                                    <label for="name" class="product-form-label required">Product Name</label>
                                    <input
                                        type="text"
                                        id="name"
                                        name="product[name]"
                                        class="product-form-input"
                                        value="<%= product.name %>"
                                        required
                                    >
                                </div>

                                <div class="product-form-group">
                                    <label for="description" class="product-form-label required">Description</label>
                                    <textarea
                                        id="description"
                                        name="product[description]"
                                        class="product-form-textarea"
                                        required
                                        rows="5"
                                    ><%= product.description %></textarea>
                                </div>

                                <div class="product-form-row">
                                    <div class="product-form-group">
                                        <label for="price" class="product-form-label required">Price ($)</label>
                                        <input
                                            type="number"
                                            id="price"
                                            name="product[price]"
                                            class="product-form-input"
                                            value="<%= product.price %>"
                                            step="0.01"
                                            min="0"
                                            required
                                        >
                                    </div>
                                    <div class="product-form-group">
                                        <label for="quantity" class="product-form-label required">Quantity Available</label>
                                        <input
                                            type="number"
                                            id="quantity"
                                            name="product[quantity]"
                                            class="product-form-input"
                                            value="<%= product.quantity %>"
                                            min="0"
                                            required
                                        >
                                    </div>
                                </div>
                                
                                <div class="product-form-group">
                                    <label for="imageFile" class="product-form-label">Update Image</label>
                                    <input
                                        type="file"
                                        id="imageFile"
                                        name="image"
                                        class="product-form-input"
                                        accept="image/png, image/jpeg, image/jpg"
                                    >
                                    <small class="product-form-help">Upload a new file to replace the current image. Leave blank to keep the existing one.</small>
                                </div>

                                <div class="product-form-actions">
                                    <a href="/products/<%= product._id %>" class="product-form-btn product-form-btn-secondary">Cancel</a>
                                    <button type="submit" class="product-form-btn product-form-btn-primary">Update Product</button>
                                </div>
                            </div>

                            <div class="product-form-preview">
                                <div class="product-form-preview-card">
                                    <h3>Current Image</h3>
                                    <div class="product-form-preview-image">
                                        <% if (product.image && product.image.url) { %>
                                            <img id="imagePreview" src="<%= product.image.url %>" alt="Current product preview">
                                        <% } else { %>
                                             <p>No image available.</p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </main>
        <%- include('../partials/footer') %>
    </div>
    <script src="/js/product-form.js"></script>
</body>
</html>