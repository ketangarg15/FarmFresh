<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Product - FarmFresh</title>
    <link rel="stylesheet" href="/css/product-form.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="product-form-container">
        <main class="product-form-main">
            <div class="product-form-content">
                <div class="product-form-title-section">
                    <h2 class="product-form-title">Add New Product</h2>
                    <p class="product-form-subtitle">Share your fresh produce with the community</p>
                </div>

                <div class="product-form-wrapper">
                    <form method="POST" action="/products" class="product-form" id="productForm" enctype="multipart/form-data">
                        <div class="product-form-grid">
                            <div class="product-form-fields">
                                <div class="product-form-group">
                                    <label for="name" class="product-form-label required">Product Name</label>
                                    <input 
                                        type="text" 
                                        id="name" 
                                        name="product[name]" 
                                        class="product-form-input"
                                        placeholder="e.g., Fresh Organic Tomatoes"
                                        required
                                    >
                                    <div class="product-form-error" id="nameError"></div>
                                </div>

                                <div class="product-form-group">
                                    <label for="description" class="product-form-label required">Description</label>
                                    <textarea 
                                        id="description" 
                                        name="product[description]" 
                                        class="product-form-textarea"
                                        placeholder="Describe your product, growing methods, taste, etc."
                                        required
                                        rows="5"
                                    ></textarea>
                                    <div class="product-form-char-count"><span id="descriptionCount">0</span>/500 characters</div>
                                    <div class="product-form-error" id="descriptionError"></div>
                                </div>

                                <div class="product-form-row">
                                    <div class="product-form-group">
                                        <label for="price" class="product-form-label required">Price ($)</label>
                                        <input 
                                            type="number" 
                                            id="price" 
                                            name="product[price]" 
                                            class="product-form-input"
                                            placeholder="0.00"
                                            step="0.01"
                                            min="0"
                                            required
                                        >
                                        <div class="product-form-error" id="priceError"></div>
                                    </div>
                                    <div class="product-form-group">
                                        <label for="quantity" class="product-form-label required">Quantity Available</label>
                                        <input 
                                            type="number" 
                                            id="quantity" 
                                            name="product[quantity]" 
                                            class="product-form-input"
                                            placeholder="0"
                                            min="0"
                                            required
                                        >
                                        <div class="product-form-error" id="quantityError"></div>
                                    </div>
                                </div>
                                
                                <div class="product-form-row">
                                    <div class="product-form-group">
                                        <label for="category" class="product-form-label required">Category</label>
                                        <select id="category" name="product[category]" class="product-form-select" required>
                                            <option value="" disabled selected>Select a category...</option>
                                            <option value="vegetable">Vegetable</option>
                                            <option value="fruit">Fruit</option>
                                            <option value="dairy">Dairy</option>
                                            <option value="meat">Meat</option>
                                            <option value="grain">Grain</option>
                                            <option value="other">Other</option>
                                        </select>
                                        <div class="product-form-error" id="categoryError"></div>
                                    </div>

                                    <div class="product-form-group">
                                        <label for="unit" class="product-form-label">Price Unit</label>
                                        <select id="unit" name="product[unit]" class="product-form-select">
                                            <option value="lb">per lb</option>
                                            <option value="kg">per kg</option>
                                            <option value="item">per item</option>
                                            <option value="bunch">per bunch</option>
                                            <option value="dozen">per dozen</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="product-form-group">
                                    <label for="imageFile" class="product-form-label required">Product Image</label>
                                    <input 
                                        type="file" 
                                        id="imageFile" 
                                        name="image" 
                                        class="product-form-input"
                                        accept="image/png, image/jpeg, image/jpg"
                                        required
                                    >
                                    <div class="product-form-error" id="imageError"></div>
                                </div>
                                
                                <div class="product-form-actions">
                                    <a href="/products" class="product-form-btn product-form-btn-secondary">Cancel</a>
                                    <button type="submit" class="product-form-btn product-form-btn-primary" id="submitBtn">Add Product</button>
                                </div>
                            </div>

                            <div class="product-form-preview">
                                <div class="product-form-preview-card">
                                    <h3 class="product-form-preview-title">Live Preview</h3>
                                    <div class="product-form-preview-image">
                                        <img 
                                            id="imagePreview" 
                                            src="/images/placeholder-product.jpg" 
                                            alt="Product preview"
                                            class="product-form-preview-img"
                                        >
                                    </div>
                                    <div class="product-form-preview-info">
                                        <h4 class="product-form-preview-name" id="previewName">Product Name</h4>
                                        <p class="product-form-preview-price" id="previewPrice">$0.00</p>
                                        <p class="product-form-preview-category" id="previewCategory">Category</p>
                                        <p class="product-form-preview-description" id="previewDescription">Product description will appear here...</p>
                                        <p class="product-form-preview-stock" id="previewStock">0 available</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </main>

        <%- include('../partials/footer') %>
    </div>
    <script src="/js/product-form.js"></script>
</body>
</html>