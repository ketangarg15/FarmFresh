<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - FarmFresh</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/products-show.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header') %>
  <%- include('../partials/flash') %>
  <% const avg = typeof averageRating !== 'undefined' ? averageRating : 0; %>
  <main class="product-main container mt-4">
    <div class="product-content row">
      <!-- Product Details -->
      <div class="col-md-7">
        <div class="card mb-4">
          <div class="product-gallery">
            <img src="<%= product.image.url %>" alt="<%= product.name %>" class="img-fluid rounded">
          </div>
        </div>
      </div>

      <div class="col-md-5">
        <div class="card p-3 shadow-sm">
          <span class="text-muted"><%= product.category || 'General' %></span>
          <h2><%= product.name %></h2>
          <div class="mb-2">
  <% if (avg > 0) { %>
    <% for (let i = 1; i <= 5; i++) { %>
      <i class="bi <%= i <= avg ? 'bi-star-fill text-warning' : (i - avg < 1 ? 'bi-star-half text-warning' : 'bi-star text-muted') %>"></i>
    <% } %>
    <span class="text-muted">(<%= avg %> / 5)</span>
  <% } else { %>
    <span class="text-muted">No ratings yet</span>
  <% } %>
</div>
          <% if (product.farmer) { %>
            <p>Sold by: 
              <a href="/farmers/<%= product.farmer._id %>">
                <%= product.farmer.username %>
              </a>
            </p>
          <% } %>
          
          <%
  // Generate dummy discount % between 10% and 50%
  const discountPercent = Math.floor(Math.random() * 41) + 10;

  // Reverse-calculate original price
  const originalPrice = product.price / (1 - discountPercent / 100);
%>

<div class="product-price-section mt-2">
  <span class="old-price">₹<%= originalPrice.toFixed(0) %></span>
  <span class="new-price">₹<%= Number(product.price).toFixed(2) %></span>
  <span class="discount-badge">(<%= discountPercent %>% OFF)</span>

  <% if (product.unit) { %>
    <small class="text-muted">/ <%= product.unit %></small>
  <% } %>
</div>


          <p class="mt-3"><%= product.description || 'No description provided.' %></p>

          <!-- Order Form -->
          <form action="/orders" method="POST" class="mt-3">
            <input type="hidden" name="productId" value="<%= product._id %>">
            <div class="mb-3">
              <label for="quantity" class="form-label">Quantity:</label>
              <input 
                type="number" 
                id="quantity" 
                name="quantity" 
                value="1" 
                min="1" 
                max="<%= product.quantity || 100 %>" 
                class="form-control w-50"
                required
              >
            </div>
            <button type="submit" class="btn btn-success">Buy Now</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Reviews Section -->
    <div class="mt-5">
      <h3>Customer Reviews</h3>
      <% if (product.reviews && product.reviews.length > 0) { %>
        <% product.reviews.forEach(review => { %>
          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between">
                <h6>
                  <i class="bi bi-person-circle"></i>
                  <%= review.author ? review.author.username : "Anonymous" %>
                </h6>
                <div>
                  <% for (let i = 1; i <= 5; i++) { %>
                    <i class="bi <%= i <= review.rating ? 'bi-star-fill text-warning' : 'bi-star text-muted' %>"></i>
                  <% } %>
                </div>
              </div>
              <p class="mt-2"><%= review.comment %></p>
              <small class="text-muted">Posted on <%= new Date(review.createdAt).toLocaleDateString() %></small>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No reviews yet. Be the first to review this product!</p>
      <% } %>
    </div>

    <!-- Add Review Form -->
    <% if (currentUser) { %>
      <div class="mt-5">
        <h4>Add a Review</h4>
        <form action="/products/<%= product._id %>/reviews" method="POST">
          <div class="mb-3">
            <label class="form-label">Rating:</label>
            <div class="star-rating d-flex gap-2">
              <% for (let i = 1; i <= 5; i++) { %>
                <input type="radio" name="review[rating]" id="star<%= i %>" value="<%= i %>" class="d-none" required>
                <label for="star<%= i %>" class="bi bi-star fs-3 text-warning" style="cursor: pointer;"></label>
              <% } %>
            </div>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Comment:</label>
            <textarea name="review[comment]" id="comment" class="form-control" rows="3" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>

      <script>
        // Interactive star rating (fills stars when clicked)
        document.querySelectorAll('.star-rating label').forEach((label, index, all) => {
          label.addEventListener('click', () => {
            all.forEach(l => l.classList.replace('bi-star-fill', 'bi-star'));
            for (let i = 0; i <= index; i++) {
              all[i].classList.replace('bi-star', 'bi-star-fill');
            }
          });
        });
      </script>
    <% } else { %>
      <div class="alert alert-warning mt-4">
        <a href="/login">Log in</a> to write a review.
      </div>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/product-show.js"></script>
</body>
</html>
