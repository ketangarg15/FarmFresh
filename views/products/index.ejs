<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products - FarmFresh</title>
  <link rel="stylesheet" href="/css/products.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/header') %>
  <%- include('../partials/flash') %>

  <div class="products-container">
    <main class="products-main">
      <div class="products-content">
        <div class="products-title-section">
          <h2 class="products-title">Fresh Products</h2>
          <p class="products-subtitle">Discover the finest organic produce from local farmers</p>
        </div>

        <div class="products-filters">
          <form class="products-search-form" method="GET" action="/products">
            <div class="products-search-group">
              <input
                type="text"
                name="q"
                class="products-search-input"
                placeholder="Search products..."
                value="<%= typeof query !== 'undefined' ? query : '' %>"
                id="searchInput"
              >
              <button type="submit" class="products-search-btn" aria-label="Search">🔍</button>
            </div>

            <div class="products-filter-group">
              <select name="category" class="products-category-select" id="categoryFilter">
                <option value="">All Categories</option>
                <option value="vegetable" <%= typeof category !== 'undefined' && category === 'vegetable' ? 'selected' : '' %>>Vegetables</option>
                <option value="fruit" <%= typeof category !== 'undefined' && category === 'fruit' ? 'selected' : '' %>>Fruits</option>
                <option value="dairy" <%= typeof category !== 'undefined' && category === 'dairy' ? 'selected' : '' %>>Dairy</option>
                <option value="meat" <%= typeof category !== 'undefined' && category === 'meat' ? 'selected' : '' %>>Meat</option>
                <option value="grain" <%= typeof category !== 'undefined' && category === 'grain' ? 'selected' : '' %>>Grains</option>
                <option value="other" <%= typeof category !== 'undefined' && category === 'other' ? 'selected' : '' %>>Other</option>
              </select>

              <select name="sort" class="products-sort-select">
                <option value="">Sort By</option>
                <option value="price-low" <%= typeof sort !== 'undefined' && sort === 'price-low' ? 'selected' : '' %>>Price: Low to High</option>
                <option value="price-high" <%= typeof sort !== 'undefined' && sort === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
              </select>
            </div>
          </form>
        </div>

        <div class="products-grid" id="productsGrid">
          <% if (typeof products !== 'undefined' && products.length > 0) { %>
            <% products.forEach(function(product) { %>
              <%
                // Generate a dummy discount percentage (10–50%)
                const discountPercent = Math.floor(Math.random() * 41) + 10;
                // Reverse calculate the original price
                const originalPrice = product.price / (1 - discountPercent / 100);
              %>

              <div class="products-card" data-category="<%= product.category || '' %>" data-name="<%= product.name.toLowerCase() %>">
                <div class="products-card-image">
                  <% if (discountPercent > 35) { %>
                    <span class="products-discount-label">🔥 Trendy Deal</span>
                  <% } %>

                  <img
                    src="<%= (product.image && product.image.url) ? product.image.url : (typeof product.image === 'string' ? product.image : '/assets/images/apple.jpeg') %>"
                    alt="<%= product.name %>"
                    class="products-img"
                    loading="lazy"
                  >

                  <% if (typeof product.quantity !== 'undefined' && product.quantity <= 5) { %>
                    <div class="products-stock-badge">
                      <% if (product.quantity === 0) { %>
                        Out of Stock
                      <% } else { %>
                        Only <%= product.quantity %> left
                      <% } %>
                    </div>
                  <% } %>
                </div>

                <div class="products-card-content">
                  <h3 class="products-card-title"><%= product.name %></h3>
                  <p class="products-card-farmer">
                    By <span class="products-farmer-name"><%= (product.farmer && product.farmer.name) || 'Local Farmer' %></span>
                  </p>

                  <div class="products-card-rating">
                    <% if (product.averageRating > 0) { %>
                      <% for (let i = 1; i <= 5; i++) { %>
                        <i class="bi <%= i <= product.averageRating ? 'bi-star-fill text-warning' : (i - product.averageRating < 1 ? 'bi-star-half text-warning' : 'bi-star text-muted') %>"></i>
                      <% } %>
                      <span class="text-muted">(<%= product.averageRating %>)</span>
                    <% } else { %>
                      <span class="text-muted">No ratings yet</span>
                    <% } %>
                  </div>

                  <div class="products-card-price">
                    <span class="old-price">₹<%= originalPrice.toFixed(0) %></span>
                    <span class="discounted-price">₹<%= product.price.toFixed(2) %></span>
                    <span class="discount-badge">(<%= discountPercent %>% OFF)</span>
                    <% if (product.unit) { %>
                      <span class="products-price-unit">per <%= product.unit %></span>
                    <% } %>
                  </div>

                  <div class="products-card-actions">
                    <a href="/products/<%= product._id %>" class="products-btn products-btn-view">View Details</a>

                    <% if (
                      currentUser &&
                      product.farmer &&
                      (
                        product.farmer._id?.toString() === currentUser._id.toString() ||
                        product.farmer?.toString() === currentUser._id.toString()
                      )
                    ) { %>
                      <a href="/products/<%= product._id %>/edit" class="products-btn products-btn-edit">Edit Product</a>
                      <form 
      method="POST" 
      action="/products/<%= product._id %>?_method=DELETE" 
      style="display:inline;"
      onsubmit="return confirm('Are you sure you want to delete this product?');"
    >
      <button type="submit" class="products-btn products-btn-delete">Delete</button>
    </form>
                    <% } else { %>
                      <% if (product.quantity > 0) { %>
                        <form method="POST" action="/orders" class="products-order-form">
                          <input type="hidden" name="productId" value="<%= product._id %>">
                          <input type="hidden" name="quantity" value="1">
                          <button type="submit" class="products-btn products-btn-order" style="color: black;">Add to Cart</button>
                        </form>
                      <% } else { %>
                        <button class="products-btn products-btn-disabled" disabled>Out of Stock</button>
                      <% } %>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="products-empty">
              <div class="products-empty-content">
                <h3>No products found</h3>
                <p>Try adjusting your search or filter criteria.</p>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </div>

  <script src="/js/products.js"></script>
</body>
</html>
