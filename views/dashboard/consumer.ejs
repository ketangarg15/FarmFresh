<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Consumer Dashboard - FarmFresh</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="dashboard-container">
        <div class="dashboard-header">
            <h1 class="dashboard-title">
                <span class="dashboard-title-icon">🛒</span>
                Consumer Dashboard
            </h1>
            <p class="dashboard-subtitle">Discover fresh products from local farmers</p>
        </div>
        
        <div class="dashboard-welcome">
            <div class="welcome-content">
                <div class="welcome-text">
                    <h2>Hello, <%= user.name %>!</h2>
                    <p>Ready to discover fresh, local produce today?</p>
                </div>
                <div class="welcome-actions">
                    <a href="/products" class="action-btn action-btn-primary">
                        <span class="action-icon">🔍</span>
                        Browse Products
                    </a>
                </div>
            </div>
        </div>

        <div class="dashboard-grid dashboard-grid-3">
            <div class="dashboard-card stats-card">
                <div class="card-icon success">✅</div>
                <span class="stats-number">
                    <%= typeof recentOrders !== 'undefined' ? recentOrders.length : 0 %>
                </span>
                <div class="stats-label">Total Orders</div>
                <div class="stats-change">All time</div>
            </div>

            <div class="dashboard-card stats-card">
                <div class="card-icon warning">❤️</div>
                <span class="stats-number">
                    <%= typeof savedItems !== 'undefined' ? savedItems.length : 0 %>
                </span>
                <div class="stats-label">Saved Items</div>
                <div class="stats-change">Your favorites</div>
            </div>
              
            <div class="dashboard-card stats-card">
                <div class="card-icon info">💰</div>
                <span class="stats-number">$156</span>
                <div class="stats-label">Money Saved</div>
                <div class="stats-change positive">vs. grocery stores</div>
            </div>
        </div>
        
        <div class="quick-actions">
            <a href="/products" class="action-btn">
                <span class="action-icon">🥕</span>
                Browse Products
            </a>
            <a href="/orders" class="action-btn">
                <span class="action-icon">📦</span>
                My Orders
            </a>
            <a href="/saved" class="action-btn">
                <span class="action-icon">❤️</span>
                Saved Items
            </a>
            <a href="/farmers" class="action-btn">
                <span class="action-icon">🚜</span>
                Find Farmers
            </a>
        </div>
            
        <div class="dashboard-grid">
            <div class="dashboard-card expandable">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="card-icon info">📋</span>
                        Recent Orders
                    </h3>
                    <button class="card-expand-btn" aria-label="Expand card">▼</button>
                </div>
                <div class="card-content collapsed">
                    <% if (typeof recentOrders !== 'undefined' && recentOrders.length > 0) { %>
                        <ul class="dashboard-list">
                            <% recentOrders.slice(0, 5).forEach(function(order) { %>
                                <li class="dashboard-list-item">
                                    <div class="list-item-content">
                                        <div class="list-item-icon">📦</div>
                                        <div class="list-item-details">
                                            <h4>Order #<%= order.id %></h4>
                                            <p><%= order.farmerName %> • $<%= order.total %> • 
                                               <span class="status-badge <%= order.status %>"><%= order.status %></span>
                                            </p>
                                        </div>
                                    </div>
                                    <a href="/orders/<%= order.id %>" class="list-item-action">View</a>
                                </li>
                            <% }); %>
                        </ul>
                        <% if (recentOrders.length > 5) { %>
                            <p style="text-align: center; margin-top: 1rem; color: #718096;">
                                <a href="/orders" class="list-item-action">View all orders</a>
                            </p>
                        <% } %>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">📦</div>
                            <h3>No orders yet</h3>
                            <p>Start shopping for fresh, local produce</p>
                            <a href="/products" class="action-btn action-btn-primary">Browse Products</a>
                        </div>
                    <% } %>
                </div>
            </div>

            <div class="dashboard-card expandable">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="card-icon warning">❤️</span>
                        Saved Items
                    </h3>
                    <button class="card-expand-btn" aria-label="Expand card">▼</button>
                </div>
                <div class="card-content collapsed">
                    <% if (typeof savedItems !== 'undefined' && savedItems.length > 0) { %>
                        <ul class="dashboard-list">
                            <% savedItems.slice(0, 5).forEach(function(item) { %>
                                <li class="dashboard-list-item">
                                    <div class="list-item-content">
                                        <div class="list-item-icon">🥬</div>
                                        <div class="list-item-details">
                                            <h4><%= item.name %></h4>
                                            <p><%= item.farmerName %> • $<%= item.price %> per <%= item.unit %></p>
                                        </div>
                                    </div>
                                    <a href="/products/<%= item.id %>" class="list-item-action">View</a>
                                </li>
                            <% }); %>
                        </ul>
                        <% if (savedItems.length > 5) { %>
                            <p style="text-align: center; margin-top: 1rem; color: #718096;">
                                <a href="/saved" class="list-item-action">View all saved items</a>
                            </p>
                        <% } %>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">❤️</div>
                            <h3>No saved items</h3>
                            <p>Save products you love for easy access later</p>
                            <a href="/products" class="action-btn action-btn-primary">Browse Products</a>
                        </div>
                    <% } %>
                </div>
            </div>
              
            <div class="dashboard-card expandable">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="card-icon success">⭐</span>
                        Recommended for You
                    </h3>
                    <button class="card-expand-btn" aria-label="Expand card">▼</button>
                </div>
                <div class="card-content collapsed">
                    <% if (typeof recommendedProducts !== 'undefined' && recommendedProducts.length > 0) { %>
                        <ul class="dashboard-list">
                            <% recommendedProducts.slice(0, 5).forEach(function(product) { %>
                                <li class="dashboard-list-item">
                                    <div class="list-item-content">
                                        <div class="list-item-icon">🌟</div>
                                        <div class="list-item-details">
                                            <h4><%= product.name %></h4>
                                            <p><%= product.farmerName %> • $<%= product.price %> per <%= product.unit %></p>
                                        </div>
                                    </div>
                                    <a href="/products/<%= product.id %>" class="list-item-action">View</a>
                                </li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <div class="empty-state">
                            <div class="empty-state-icon">⭐</div>
                            <h3>Building recommendations</h3>
                            <p>Browse and purchase products to get personalized recommendations</p>
                            <a href="/products" class="action-btn action-btn-primary">Browse Products</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    
    <%- include('../partials/footer') %>
    <script src="/js/dashboard.js"></script>
</body>
</html>