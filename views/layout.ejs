<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= (typeof pageTitle !== 'undefined' ? pageTitle : 'FarmFresh') %></title>
  <!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

  <link rel="stylesheet" href="/css/base.css">

  <% if (Array.isArray(additionalCSS) && additionalCSS.length) { %>
    <% additionalCSS.forEach(function(f) { %>
      <link rel="stylesheet" href="<%= f %>">
    <% }); %>
  <% } %>
</head>

<body>
  <%- include('partials/header') %>

  <%- include('partials/flash') %>

  <main id="main-content">
    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/base.js" defer></script>

  <% if (Array.isArray(additionalJS) && additionalJS.length) { %>
    <% additionalJS.forEach(function(src) { %>
      <script src="<%= src %>" defer></script>
    <% }); %>
  <% } %>
</body>
</html>