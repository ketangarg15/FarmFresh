<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meet Our Farmers - FarmFresh</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/farmers.css">
</head>
<body>
  <%- include('partials/header') %>
  <%- include('partials/flash') %>

  <div class="container py-5">
    <div class="text-center mb-5">
      <h1 class="fw-bold">Meet Our Farmers</h1>
      <p class="text-muted">The dedicated individuals bringing fresh, local food to your table.</p>
    </div>

    <div class="row g-4">
      <!-- Farmer 1 -->
      <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
          <img src="/assets/images/farmerpic.jpg" class="card-img-top" alt="Ramesh Kumar">
          <div class="card-body text-center">
            <h5 class="card-title mb-1">Ramesh Kumar</h5>
            <p class="text-muted small mb-1">Green Valley Farms</p>
            <p class="text-muted small">📍 Nashik, Maharashtra</p>
            <p class="small text-secondary">Ramesh has been growing organic fruits and vegetables for over 15 years.</p>
            <a href="/farmers/1" class="btn btn-success btn-sm">View Profile</a>
          </div>
        </div>
      </div>

      <!-- Farmer 2 -->
      <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
          <img src="/assets/images/farmerpic.jpg" class="card-img-top" alt="Sita Devi">
          <div class="card-body text-center">
            <h5 class="card-title mb-1">Sita Devi</h5>
            <p class="text-muted small mb-1">Sunrise Organic Farm</p>
            <p class="text-muted small">📍 Jaipur, Rajasthan</p>
            <p class="small text-secondary">Sita specializes in producing organic grains and pulses sustainably.</p>
            <a href="/farmers/2" class="btn btn-success btn-sm">View Profile</a>
          </div>
        </div>
      </div>

      <!-- Farmer 3 -->
      <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
          <img src="/assets/images/farmerpic.jpg" class="card-img-top" alt="Aman Singh">
          <div class="card-body text-center">
            <h5 class="card-title mb-1">Aman Singh</h5>
            <p class="text-muted small mb-1">Happy Harvest Farm</p>
            <p class="text-muted small">📍 Ludhiana, Punjab</p>
            <p class="small text-secondary">Aman uses modern irrigation methods for efficient water use and high yield.</p>
            <a href="/farmers/3" class="btn btn-success btn-sm">View Profile</a>
          </div>
        </div>
      </div>

      <!-- Farmer 4 -->
      <div class="col-md-6 col-lg-3">
        <div class="card shadow-sm border-0 h-100">
          <img src="/assets/images/farmerpic.jpg" class="card-img-top" alt="Lakshmi Rao">
          <div class="card-body text-center">
            <h5 class="card-title mb-1">Lakshmi Rao</h5>
            <p class="text-muted small mb-1">Pure Earth Plantation</p>
            <p class="text-muted small">📍 Coimbatore, Tamil Nadu</p>
            <p class="small text-secondary">Lakshmi focuses on sustainable coconut and spice cultivation.</p>
            <a href="/farmers/4" class="btn btn-success btn-sm">View Profile</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
