<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmFresh - Fresh Produce Delivered</title>
    <link rel="stylesheet" href="/css/home.css">
</head>
<body>
    <div class="home-container">
        
        <%- include('partials/header') %>
        <%- include('partials/flash') %>

        <main>
            <section class="home-hero">
                <div class="home-hero-content">
                    <h1 class="home-hero-title">Fresh produce from farmers to your doorstep</h1>
                    <p class="home-hero-subtitle">Discover the finest organic fruits and vegetables, delivered fresh daily from local farms.</p>
                    <a href="#products" class="home-hero-cta">Shop Now</a>
                </div>
            </section>

            <section class="home-products" id="products">
                <div class="home-products-container">
                    <h2 class="home-products-title">Featured Products</h2>
                    <div class="home-products-grid">
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <div class="home-product-card">
                                    <a href="/products/<%= product._id %>" class="home-product-image-link">
                                        <div class="home-product-image">
                                            <img 
                                                src="<%= product.image ? product.image.url : '/images/placeholder-product.jpg' %>" 
                                                alt="<%= product.name %>"
                                                loading="lazy"
                                            >
                                        </div>
                                    </a>
                                    <div class="home-product-info">
                                        <h4><%= product.name %></h4>
                                        <p class="price">₹<%= product.price.toFixed(2) %></p>
                                        
                                        <p class="description">
                                            <% if (product.description) { %>
                                                <%= product.description.substring(0, 80) %>...
                                            <% } else { %>
                                                Fresh and organic, direct from the farm.
                                            <% } %>
                                        </p>
                                        <a href="/products/<%= product._id %>" class="btn">View Product</a>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>No featured products are available at this time.</p>
                        <% } %>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>

    </div>

    <script src="/js/home.js" defer></script>
</body>
</html>