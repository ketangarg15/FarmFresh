<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Details - <%= (delivery._id || delivery.id || '').toString().slice(-8).toUpperCase() %> - FarmFresh Admin</title>
    <link rel="stylesheet" href="/css/deliveries.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>

    <div class="delivery-show-container">
        <header class="deliveries-header">
            <nav class="deliveries-nav">
                <div class="deliveries-nav-brand">
                    <a href="/admin"><h1>FarmFresh Admin</h1></a>
                </div>
                <ul class="deliveries-nav-links">
                    <li><a href="/admin/dashboard" class="deliveries-nav-link">Dashboard</a></li>
                    <li><a href="/admin/orders" class="deliveries-nav-link">Orders</a></li>
                    <li><a href="/admin/deliveries" class="deliveries-nav-link active">Deliveries</a></li>
                    <li><a href="/admin/partners" class="deliveries-nav-link">Partners</a></li>
                    <li><a href="/admin/reports" class="deliveries-nav-link">Reports</a></li>
                    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <li><a href="/admin/profile" class="deliveries-nav-link">Profile</a></li>
                        <li><a href="/logout" class="deliveries-nav-link">Logout</a></li>
                    <% } %>
                </ul>
            </nav>
        </header>

        <div class="deliveries-breadcrumb">
            <div class="deliveries-breadcrumb-content">
                <a href="/admin" class="deliveries-breadcrumb-link">Admin</a>
                <span class="deliveries-breadcrumb-separator">›</span>
                <a href="/admin/deliveries" class="deliveries-breadcrumb-link">Deliveries</a>
                <span class="deliveries-breadcrumb-separator">›</span>
                <span class="deliveries-breadcrumb-current">
                    Delivery #<%= (delivery._id || delivery.id || '').toString().slice(-8).toUpperCase() %>
                </span>
            </div>
        </div>
        
        <main class="delivery-show-main">
            <div class="delivery-show-content">
                <div class="delivery-show-header">
                    <div class="show-header-content">
                        <h1 class="show-title">
                            Delivery Details
                            <span class="delivery-id">#<%= (delivery._id || delivery.id || '').toString().slice(-8).toUpperCase() %></span>
                        </h1>
                        <div class="show-status">
                            <span class="status-badge status-<%= (delivery.status || 'assigned').toLowerCase().replace('_', '-') %>">
                                <%= (delivery.status || 'Assigned').replace('_', ' ').split(' ').map(word => 
                                    word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
                                ).join(' ') %>
                            </span>
                        </div>
                    </div>
                        
                    <div class="show-header-actions">
                        <a href="/admin/deliveries" class="header-action-btn secondary">
                            ← Back to Deliveries
                        </a>
                        <button type="button" class="header-action-btn primary" id="updateStatusBtn">
                            🔄 Update Status
                        </button>
                        <% if (['picked_up', 'in_transit'].includes((delivery.status || '').toLowerCase())) { %>
                            <button type="button" class="header-action-btn track" id="trackDeliveryBtn">
                                📍 Track Live
                            </button>
                        <% } %>
                    </div>
                </div>

                <div class="delivery-info-grid">
                    <div class="info-card">
                        <div class="info-card-header">
                            <h3 class="info-card-title">📦 Order Information</h3>
                        </div>
                        <div class="info-card-content">
                            <div class="info-row">
                                <span class="info-label">Order ID:</span>
                                <span class="info-value">
                                    <a href="/admin/orders/<%= (delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId %>" class="order-link">
                                        #<%= ((delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId || '').toString().slice(-8).toUpperCase() %>
                                    </a>
                                </span>
                            </div>
                            
                            <% if (delivery.order && typeof delivery.order.totalAmount !== 'undefined') { %>
                                <div class="info-row">
                                    <span class="info-label">Order Value:</span>
                                    <span class="info-value order-amount">$<%= delivery.order.totalAmount.toFixed(2) %></span>
                                </div>
                            <% } %>
                            
                            <div class="info-row">
                                <span class="info-label">Order Date:</span>
                                <span class="info-value">
                                    <%= new Date((delivery.order && delivery.order.createdAt) || delivery.createdAt || new Date()).toLocaleString('en-US', { 
                                      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit'
                                    }) %>
                                </span>
                            </div>
                                
                            <% if (delivery.order && delivery.order.products && delivery.order.products.length > 0) { %>
                                <div class="info-row">
                                    <span class="info-label">Items:</span>
                                    <span class="info-value">
                                        <%= delivery.order.products.reduce((total, item) => total + (item.quantity || 1), 0) %> items
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-card-header">
                            <h3 class="info-card-title">👤 Customer Information</h3>
                        </div>
                        <div class="info-card-content">
                            <div class="info-row">
                                <span class="info-label">Name:</span>
                                <span class="info-value">
                                    <%= (delivery.order && delivery.order.consumer && (delivery.order.consumer.name || delivery.order.consumer.firstName + ' ' + (delivery.order.consumer.lastName || ''))) || delivery.customerName || 'Customer' %>
                                </span>
                            </div>
                            
                            <% if (delivery.order && delivery.order.consumer && delivery.order.consumer.email) { %>
                                <div class="info-row">
                                    <span class="info-label">Email:</span>
                                    <span class="info-value">
                                        <a href="mailto:<%= delivery.order.consumer.email %>" class="contact-link">
                                            <%= delivery.order.consumer.email %>
                                        </a>
                                    </span>
                                </div>
                            <% } %>
                            
                            <% if (delivery.order && delivery.order.consumer && delivery.order.consumer.phone) { %>
                                <div class="info-row">
                                    <span class="info-label">Phone:</span>
                                    <span class="info-value">
                                        <a href="tel:<%= delivery.order.consumer.phone %>" class="contact-link">
                                            <%= delivery.order.consumer.phone %>
                                        </a>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="status-history-container">
                    </div>

                <% if (delivery.order && delivery.order.products && delivery.order.products.length > 0) { %>
                    <div class="order-items-container">
                        </div>
                <% } %>
            </div>
        </main>

        <footer class="deliveries-footer">
            <div class="deliveries-footer-content">
                <p>© 2024 FarmFresh Admin. All rights reserved.</p>
                <div class="deliveries-footer-links">
                    <a href="/admin/help">Help</a>
                    <a href="/admin/support">Support</a>
                    <a href="/admin/settings">Settings</a>
                </div>
            </div>
        </footer>
    </div>
    
    <div class="modal-overlay" id="statusUpdateModal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Update Delivery Status</h3>
                <button type="button" class="modal-close" id="closeStatusModal">×</button>
            </div>
            <div class="modal-body">
                <form id="deliveryStatusForm" class="status-update-form">
                    <div class="form-group">
                        <label for="deliveryStatus" class="form-label">New Status:</label>
                        <select id="deliveryStatus" name="status" class="form-select" required>
                            <option value="assigned" <%= (delivery.status || 'assigned') === 'assigned' ? 'selected' : '' %>>Assigned</option>
                            <option value="picked_up" <%= (delivery.status || '') === 'picked_up' ? 'selected' : '' %>>Picked Up</option>
                            <option value="in_transit" <%= (delivery.status || '') === 'in_transit' ? 'selected' : '' %>>In Transit</option>
                            <option value="delivered" <%= (delivery.status || '') === 'delivered' ? 'selected' : '' %>>Delivered</option>
                            <option value="failed" <%= (delivery.status || '') === 'failed' ? 'selected' : '' %>>Failed</option>
                            <option value="returned" <%= (delivery.status || '') === 'returned' ? 'selected' : '' %>>Returned</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="statusNotes" class="form-label">Notes:</label>
                        <textarea id="statusNotes" name="notes" class="form-textarea" placeholder="Add notes about this status update..."></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="form-btn secondary" id="cancelStatusUpdate">Cancel</button>
                        <button type="submit" class="form-btn primary" id="updateStatusSubmit">Update Status</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <script src="/js/deliveries.js"></script>
    
    <script>
        window.deliveryData = {
            id: '<%= delivery._id || delivery.id %>',
            // CORRECTED: "assigned" must be in quotes to be a string
            status: '<%= delivery.status || "assigned" %>',
            // CORRECTED: Completed the line and added a fallback
            orderId: '<%= (delivery.order && (delivery.order._id || delivery.order.id)) || "" %>'
        };
    </script>
</body>
</html>