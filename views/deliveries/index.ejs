<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Management - FarmFresh Admin</title>
    <link rel="stylesheet" href="/css/deliveries.css">
</head>
<body>
    <%- include('../partials/header') %>
    <%- include('../partials/flash') %>
    
    <div class="deliveries-container">
        <header class="deliveries-header">
            <nav class="deliveries-nav">
                <div class="deliveries-nav-brand">
                    <a href="/admin"><h1>FarmFresh Admin</h1></a>
                </div>
                <ul class="deliveries-nav-links">
                    <li><a href="/admin/dashboard" class="deliveries-nav-link">Dashboard</a></li>
                    <li><a href="/admin/orders" class="deliveries-nav-link">Orders</a></li>
                    <li><a href="/admin/deliveries" class="deliveries-nav-link active">Deliveries</a></li>
                    <li><a href="/admin/partners" class="deliveries-nav-link">Partners</a></li>
                    <li><a href="/admin/reports" class="deliveries-nav-link">Reports</a></li>
                    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <li><a href="/admin/profile" class="deliveries-nav-link">Profile</a></li>
                        <li><a href="/logout" class="deliveries-nav-link">Logout</a></li>
                    <% } %>
                </ul>
            </nav>
        </header>

        <div class="deliveries-breadcrumb">
            <div class="deliveries-breadcrumb-content">
                <a href="/admin" class="deliveries-breadcrumb-link">Admin</a>
                <span class="deliveries-breadcrumb-separator">›</span>
                <span class="deliveries-breadcrumb-current">Delivery Management</span>
            </div>
        </div>

        <main class="deliveries-main">
            <div class="deliveries-content">
                <div class="deliveries-page-header">
                    <div class="page-header-content">
                        <h1 class="page-title">Delivery Management</h1>
                        <p class="page-subtitle">Track and manage all delivery assignments and status updates</p>
                    </div>
                    
                    <div class="page-header-actions">
                        <button type="button" class="header-action-btn refresh-btn" id="refreshDeliveries">
                            🔄 Refresh
                        </button>
                        <a href="/admin/deliveries/assign" class="header-action-btn primary-btn">
                            ➕ Assign Delivery
                        </a>
                        <button type="button" class="header-action-btn filter-btn" id="filterToggle">
                            🔍 Filters
                        </button>
                    </div>
                </div>

                <div class="deliveries-filters" id="filtersSection" style="display: none;">
                    <div class="filters-content">
                        <div class="filter-group">
                            <label for="statusFilter" class="filter-label">Status:</label>
                            <select id="statusFilter" class="filter-select">
                                <option value="">All Statuses</option>
                                <option value="assigned">Assigned</option>
                                <option value="picked_up">Picked Up</option>
                                <option value="in_transit">In Transit</option>
                                <option value="delivered">Delivered</option>
                                <option value="failed">Failed</option>
                                <option value="returned">Returned</option>
                            </select>
                        </div>
                    
                        <div class="filter-group">
                            <label for="partnerFilter" class="filter-label">Partner:</label>
                            <select id="partnerFilter" class="filter-select">
                                <option value="">All Partners</option>
                                <% if (typeof deliveries !== 'undefined' && deliveries.length > 0) { %>
                                    <% 
                                        const uniquePartners = [...new Set(deliveries.map(d => d.partnerName).filter(Boolean))];
                                        uniquePartners.forEach(partner => {
                                    %>
                                        <option value="<%= partner %>"><%= partner %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                    
                        <div class="filter-group">
                            <label for="dateFilter" class="filter-label">Date:</label>
                            <input type="date" id="dateFilter" class="filter-input">
                        </div>
                        
                        <div class="filter-actions">
                            <button type="button" class="filter-action-btn apply-btn" id="applyFilters">
                                Apply Filters
                            </button>
                            <button type="button" class="filter-action-btn clear-btn" id="clearFilters">
                                Clear All
                            </button>
                        </div>
                    </div>
                </div>

                <div class="deliveries-stats">
                    <% 
                        let totalDeliveries = 0;
                        let assignedCount = 0;
                        let inTransitCount = 0;
                        let deliveredCount = 0;
                        let failedCount = 0;
                        if (typeof deliveries !== 'undefined' && deliveries.length > 0) {
                            totalDeliveries = deliveries.length;
                            assignedCount = deliveries.filter(d => (d.status || '').toLowerCase() === 'assigned').length;
                            inTransitCount = deliveries.filter(d => ['picked_up', 'in_transit'].includes((d.status || '').toLowerCase())).length;
                            deliveredCount = deliveries.filter(d => (d.status || '').toLowerCase() === 'delivered').length;
                            failedCount = deliveries.filter(d => ['failed', 'returned'].includes((d.status || '').toLowerCase())).length;
                        }
                    %>
                    
                    <div class="stat-card stat-total">
                        <div class="stat-icon">📦</div>
                        <div class="stat-content">
                            <div class="stat-number"><%= totalDeliveries %></div>
                            <div class="stat-label">Total Deliveries</div>
                        </div>
                    </div>
                    
                    <div class="stat-card stat-assigned">
                        <div class="stat-icon">📋</div>
                        <div class="stat-content">
                            <div class="stat-number"><%= assignedCount %></div>
                            <div class="stat-label">Assigned</div>
                        </div>
                    </div>
                    
                    <div class="stat-card stat-transit">
                        <div class="stat-icon">🚚</div>
                        <div class="stat-content">
                            <div class="stat-number"><%= inTransitCount %></div>
                            <div class="stat-label">In Transit</div>
                        </div>
                    </div>
                    
                    <div class="stat-card stat-delivered">
                        <div class="stat-icon">✅</div>
                        <div class="stat-content">
                            <div class="stat-number"><%= deliveredCount %></div>
                            <div class="stat-label">Delivered</div>
                        </div>
                    </div>
                    
                    <div class="stat-card stat-failed">
                        <div class="stat-icon">❌</div>
                        <div class="stat-content">
                            <div class="stat-number"><%= failedCount %></div>
                            <div class="stat-label">Failed/Returned</div>
                        </div>
                    </div>
                </div>

                <div class="deliveries-table-container">
                    <div class="table-header">
                        <h2 class="table-title">All Deliveries</h2>
                        <div class="table-actions">
                            <button type="button" class="table-action-btn export-btn" id="exportDeliveries">
                                📊 Export CSV
                            </button>
                            <div class="table-view-toggle">
                                <button type="button" class="view-toggle-btn active" data-view="table" id="tableViewBtn">
                                    📋 Table
                                </button>
                                <button type="button" class="view-toggle-btn" data-view="cards" id="cardsViewBtn">
                                    🗃️ Cards
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="deliveries-table-wrapper" id="tableView">
                        <% if (typeof deliveries !== 'undefined' && deliveries.length > 0) { %>
                            <table class="deliveries-table" id="deliveriesTable">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-sort="orderId">
                                            Order ID
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th class="sortable" data-sort="partner">
                                            Delivery Partner
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th class="sortable" data-sort="status">
                                            Status
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th class="sortable" data-sort="assignedAt">
                                            Assigned Date
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th class="sortable" data-sort="customer">
                                            Customer
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th class="sortable" data-sort="address">
                                            Delivery Address
                                            <span class="sort-indicator">↕️</span>
                                        </th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% deliveries.forEach(function(delivery) { %>
                                        <tr class="delivery-row" data-delivery-id="<%= delivery._id || delivery.id %>">
                                            
                                            <td class="order-id-cell">
                                                <a href="/admin/orders/<%= (delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId %>" 
                                                   class="order-link">
                                                    #<%= ((delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId || '').toString().slice(-8).toUpperCase() %>
                                                </a>
                                                <% if (delivery.order && delivery.order.totalAmount) { %>
                                                    <div class="order-amount">$<%= delivery.order.totalAmount.toFixed(2) %></div>
                                                <% } %>
                                            </td>
                                            
                                            <td class="partner-cell">
                                                <div class="partner-info">
                                                    <div class="partner-name">
                                                        <%= delivery.partnerName || (delivery.partner && delivery.partner.name) || 'Unassigned' %>
                                                    </div>
                                                    <% if (delivery.partner && delivery.partner.phone) { %>
                                                        <div class="partner-contact">
                                                            📞 <%= delivery.partner.phone %>
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>
                                            
                                            <td class="status-cell">
                                                <span class="status-badge status-<%= (delivery.status || 'assigned').toLowerCase().replace('_', '-') %>">
                                                    <%= (delivery.status || 'Assigned').replace('_', ' ').split(' ').map(word => 
                                                        word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
                                                    ).join(' ') %>
                                                </span>
                                                <% if (delivery.estimatedDelivery) { %>
                                                    <div class="estimated-time">
                                                        ETA: <%= new Date(delivery.estimatedDelivery).toLocaleDateString('en-US', { 
                                                            month: 'short', 
                                                            day: 'numeric',
                                                            hour: '2-digit',
                                                            minute: '2-digit'
                                                        }) %>
                                                    </div>
                                                <% } %>
                                            </td>
                                            
                                            <td class="date-cell">
                                                <%= new Date(delivery.assignedAt || delivery.createdAt || new Date()).toLocaleDateString('en-US', { 
                                                    month: 'short', 
                                                    day: 'numeric',
                                                    year: 'numeric'
                                                }) %>
                                                <div class="time-detail">
                                                    <%= new Date(delivery.assignedAt || delivery.createdAt || new Date()).toLocaleTimeString('en-US', { 
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    }) %>
                                                </div>
                                            </td>
                                            
                                            <td class="customer-cell">
                                                <div class="customer-name">
                                                    <%= (delivery.order && delivery.order.consumer && 
                                                        (delivery.order.consumer.name || delivery.order.consumer.firstName + ' ' + (delivery.order.consumer.lastName || ''))) || 
                                                        delivery.customerName || 'Customer' %>
                                                </div>
                                                <% if (delivery.order && delivery.order.consumer && delivery.order.consumer.phone) { %>
                                                    <div class="customer-contact">
                                                        📞 <%= delivery.order.consumer.phone %>
                                                    </div>
                                                <% } %>
                                            </td>
                                            
                                            <td class="address-cell">
                                                <div class="delivery-address">
                                                    <% if (delivery.deliveryAddress) { %>
                                                        <%= delivery.deliveryAddress.street || delivery.deliveryAddress %><br>
                                                        <% if (typeof delivery.deliveryAddress === 'object') { %>
                                                            <%= delivery.deliveryAddress.city || '' %>, 
                                                            <%= delivery.deliveryAddress.state || '' %> 
                                                            <%= delivery.deliveryAddress.zipCode || '' %>
                                                        <% } %>
                                                    <% } else if (delivery.order && delivery.order.deliveryInfo && delivery.order.deliveryInfo.address) { %>
                                                        <%= delivery.order.deliveryInfo.address.street %><br>
                                                        <%= delivery.order.deliveryInfo.address.city %>, 
                                                        <%= delivery.order.deliveryInfo.address.state %> 
                                                        <%= delivery.order.deliveryInfo.address.zipCode %>
                                                    <% } else { %>
                                                        Address not available
                                                    <% } %>
                                                </div>
                                            </td>
                                          
                                            <td class="actions-cell">
                                                <div class="action-buttons">
                                                    <a href="/admin/deliveries/<%= delivery._id || delivery.id %>" 
                                                       class="action-btn view-btn" 
                                                       title="View Details">
                                                        👁️
                                                    </a>
                                                    
                                                    <% if (!['delivered', 'failed', 'returned'].includes((delivery.status || '').toLowerCase())) { %>
                                                        <button type="button" 
                                                                class="action-btn update-btn" 
                                                                data-delivery-id="<%= delivery._id || delivery.id %>"
                                                                data-current-status="<%= delivery.status || 'assigned' %>"
                                                                title="Update Status">
                                                            🔄
                                                        </button>
                                                    <% } %>
                                                    
                                                    <% if (['picked_up', 'in_transit'].includes((delivery.status || '').toLowerCase())) { %>
                                                        <button type="button" 
                                                                class="action-btn track-btn" 
                                                                data-delivery-id="<%= delivery._id || delivery.id %>"
                                                                title="Track Delivery">
                                                            📍
                                                        </button>
                                                    <% } %>
                                                    
                                                    <% if (delivery.partner && delivery.partner.phone) { %>
                                                        <a href="tel:<%= delivery.partner.phone %>" 
                                                           class="action-btn contact-btn" 
                                                           title="Call Partner">
                                                            📞
                                                        </a>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        <% } else { %>
                            <div class="empty-state">
                                <div class="empty-icon">📦</div>
                                <h3 class="empty-title">No Deliveries Found</h3>
                                <p class="empty-message">There are no delivery assignments to display.</p>
                                <a href="/admin/deliveries/assign" class="empty-action-btn">
                                    ➕ Assign First Delivery
                                </a>
                            </div>
                        <% } %>
                    </div>

                    <div class="deliveries-cards-wrapper" id="cardsView" style="display: none;">
                        <% if (typeof deliveries !== 'undefined' && deliveries.length > 0) { %>
                            <div class="deliveries-cards">
                                <% deliveries.forEach(function(delivery) { %>
                                    <div class="delivery-card" data-delivery-id="<%= delivery._id || delivery.id %>">
                                        
                                        <div class="card-header">
                                            <div class="card-order-info">
                                                <a href="/admin/orders/<%= (delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId %>" 
                                                   class="card-order-link">
                                                    Order #<%= ((delivery.order && (delivery.order._id || delivery.order.id)) || delivery.orderId || '').toString().slice(-8).toUpperCase() %>
                                                </a>
                                                <% if (delivery.order && delivery.order.totalAmount) { %>
                                                    <span class="card-order-amount">$<%= delivery.order.totalAmount.toFixed(2) %></span>
                                                <% } %>
                                            </div>
                                            <span class="card-status-badge status-<%= (delivery.status || 'assigned').toLowerCase().replace('_', '-') %>">
                                                <%= (delivery.status || 'Assigned').replace('_', ' ').split(' ').map(word => 
                                                    word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
                                                ).join(' ') %>
                                            </span>
                                        </div>
                                        
                                        <div class="card-content">
                                            <div class="card-section">
                                                <div class="card-section-label">Delivery Partner:</div>
                                                <div class="card-section-value">
                                                    <%= delivery.partnerName || (delivery.partner && delivery.partner.name) || 'Unassigned' %>
                                                    <% if (delivery.partner && delivery.partner.phone) { %>
                                                        <a href="tel:<%= delivery.partner.phone %>" class="card-phone-link">
                                                            📞 <%= delivery.partner.phone %>
                                                        </a>
                                                    <% } %>
                                                </div>
                                            </div>
                                              
                                            <div class="card-section">
                                                <div class="card-section-label">Customer:</div>
                                                <div class="card-section-value">
                                                    <%= (delivery.order && delivery.order.consumer && 
                                                        (delivery.order.consumer.name || delivery.order.consumer.firstName + ' ' + (delivery.order.consumer.lastName || ''))) || 
                                                        delivery.customerName || 'Customer' %>
                                                </div>
                                            </div>
                                        
                                            <div class="card-section">
                                                <div class="card-section-label">Delivery Address:</div>
                                                <div class="card-section-value card-address">
                                                    <% if (delivery.deliveryAddress) { %>
                                                        <%= delivery.deliveryAddress.street || delivery.deliveryAddress %><br>
                                                        <% if (typeof delivery.deliveryAddress === 'object') { %>
                                                            <%= delivery.deliveryAddress.city || '' %>, 
                                                            <%= delivery.deliveryAddress.state || '' %> 
                                                            <%= delivery.deliveryAddress.zipCode || '' %>
                                                        <% } %>
                                                    <% } else if (delivery.order && delivery.order.deliveryInfo && delivery.order.deliveryInfo.address) { %>
                                                        <%= delivery.order.deliveryInfo.address.street %><br>
                                                        <%= delivery.order.deliveryInfo.address.city %>, 
                                                        <%= delivery.order.deliveryInfo.address.state %> 
                                                        <%= delivery.order.deliveryInfo.address.zipCode %>
                                                    <% } else { %>
                                                        Address not available
                                                    <% } %>
                                                </div>
                                            </div>
                                            
                                            <div class="card-section">
                                                <div class="card-section-label">Assigned:</div>
                                                <div class="card-section-value">
                                                    <%= new Date(delivery.assignedAt || delivery.createdAt || new Date()).toLocaleString('en-US', { 
                                                        month: 'short', 
                                                        day: 'numeric',
                                                        year: 'numeric',
                                                        hour: '2-digit',
                                                        minute: '2-digit'
                                                    }) %>
                                                </div>
                                            </div>
                                            
                                            <% if (delivery.estimatedDelivery) { %>
                                                <div class="card-section">
                                                    <div class="card-section-label">Estimated Delivery:</div>
                                                    <div class="card-section-value card-eta">
                                                        <%= new Date(delivery.estimatedDelivery).toLocaleString('en-US', { 
                                                            month: 'short', 
                                                            day: 'numeric',
                                                            hour: '2-digit',
                                                            minute: '2-digit'
                                                        }) %>
                                                    </div>
                                                </div>
                                            <% } %>
                                        </div>
                                        
                                        <div class="card-actions">
                                            <a href="/admin/deliveries/<%= delivery._id || delivery.id %>" 
                                               class="card-action-btn primary">
                                                View Details
                                            </a>
                                            
                                            <% if (!['delivered', 'failed', 'returned'].includes((delivery.status || '').toLowerCase())) { %>
                                                <button type="button" 
                                                        class="card-action-btn secondary update-btn" 
                                                        data-delivery-id="<%= delivery._id || delivery.id %>"
                                                        data-current-status="<%= delivery.status || 'assigned' %>">
                                                    Update Status
                                                </button>
                                            <% } %>
                                            
                                            <% if (['picked_up', 'in_transit'].includes((delivery.status || '').toLowerCase())) { %>
                                                <button type="button" 
                                                        class="card-action-btn track track-btn" 
                                                        data-delivery-id="<%= delivery._id || delivery.id %>">
                                                    Track
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <div class="empty-state">
                                <div class="empty-icon">📦</div>
                                <h3 class="empty-title">No Deliveries Found</h3>
                                <p class="empty-message">There are no delivery assignments to display.</p>
                                <a href="/admin/deliveries/assign" class="empty-action-btn">
                                    ➕ Assign First Delivery
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (typeof deliveries !== 'undefined' && deliveries.length > 10) { %>
                    <div class="deliveries-pagination">
                        <div class="pagination-info">
                            Showing 1-<%= Math.min(10, deliveries.length) %> of <%= deliveries.length %> deliveries
                        </div>
                        <div class="pagination-controls">
                            <button type="button" class="pagination-btn" disabled>← Previous</button>
                            <button type="button" class="pagination-btn active">1</button>
                            <% if (deliveries.length > 10) { %>
                                <button type="button" class="pagination-btn">2</button>
                                <% if (deliveries.length > 20) { %>
                                    <span class="pagination-dots">...</span>
                                <% } %>
                            <% } %>
                            <button type="button" class="pagination-btn" <%= deliveries.length <= 10 ? 'disabled' : '' %>>Next →</button>
                        </div>
                    </div>
                <% } %>
            </div>
        </main>
        
        <%- include('../partials/footer') %>
    </div>

    <div class="modal-overlay" id="statusUpdateModal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Update Delivery Status</h3>
                <button type="button" class="modal-close" id="closeStatusModal">×</button>
            </div>
            <div class="modal-body">
                <form id="statusUpdateForm">
                    <input type="hidden" id="updateDeliveryId" name="deliveryId">
                    
                    <div class="form-group">
                        <label for="newStatus" class="form-label">New Status:</label>
                        <select id="newStatus" name="status" class="form-select" required>
                            <option value="">Select Status</option>
                            <option value="assigned">Assigned</option>
                            <option value="picked_up">Picked Up</option>
                            <option value="in_transit">In Transit</option>
                            <option value="delivered">Delivered</option>
                            <option value="failed">Failed</option>
                            <option value="returned">Returned</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="statusNotes" class="form-label">Notes (Optional):</label>
                        <textarea id="statusNotes" name="notes" class="form-textarea" 
                                  placeholder="Add any additional notes about this status update..."></textarea>
                    </div>
                    
                    <div class="form-actions">
                        <button type="button" class="form-btn secondary" id="cancelStatusUpdate">
                            Cancel
                        </button>
                        <button type="submit" class="form-btn primary">
                            Update Status
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="/js/deliveries.js"></script>
</body>
</html>